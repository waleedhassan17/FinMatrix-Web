{
  "name": "finmatrix",
  "version": "0.1.0",
  "private": true,
  "description": "FinMatrix - Multi-tenant Accounting Software for Pakistani SMBs",
  "scripts": {
    "dev": "pnpm --filter @finmatrix/web dev",
    "build": "pnpm --filter @finmatrix/web build",
    "start": "pnpm --filter @finmatrix/web start",
    "heroku-postbuild": "npx pnpm install --frozen-lockfile && npx pnpm run build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @finmatrix/db generate",
    "db:migrate": "pnpm --filter @finmatrix/db migrate",
    "db:push": "pnpm --filter @finmatrix/db push",
    "db:studio": "pnpm --filter @finmatrix/db studio",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.0",
    "prettier-plugin-tailwindcss": "^0.5.9",
    "turbo": "^1.11.0",
    "typescript": "^5.3.2"
  },
  "packageManager": "pnpm@8.12.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
